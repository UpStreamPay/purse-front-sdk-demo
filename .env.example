# Copy to .env.local and fill in your values.

# ── Headless Checkout / Drop-in ──────────────────────────────────────────────
VITE_PURSE_API_KEY=your-api-key-here
VITE_PURSE_ENTITY_ID=your-entity-id-here

# Paste a full payment session JSON here for local testing.
# In production, replace getSession() in each recipe with your backend call.
VITE_PURSE_SESSION_JSON=

# ── Secure Fields ─────────────────────────────────────────────────────────────
VITE_PURSE_SECUREFIELDS_TENANT_ID=your-tenant-id-here
# VITE_PURSE_API_KEY is shared with Headless Checkout above.

# ── Environment (optional, defaults to "sandbox") ────────────────────────────
# VITE_PURSE_ENVIRONMENT=sandbox

