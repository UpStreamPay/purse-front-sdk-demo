{
  "name": "@upstreampay/purse-sdk-demos",
  "version": "0.11.0",
  "description": "Sandpack demo configs for the Purse SDK documentation",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "vite --port 8000",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "registry": "npx verdaccio --config verdaccio.config.yaml",
    "publish:local": "npm run build && npm publish --registry http://localhost:4873"
  },
  "peerDependencies": {
    "@codesandbox/sandpack-react": "^2",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "release-it": {
    "git": {
      "requireCleanWorkingDir": false,
      "commitMessage": "chore(release): ${version}",
      "tagName": "@upstreampay/purse-sdk-demos@${version}"
    },
    "github": {
      "release": false
    },
    "npm": {
      "publish": false
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular"
      }
    }
  },
  "devDependencies": {
    "@codesandbox/sandpack-react": "^2.18.4",
    "@purse-eu/web-sdk": "latest",
    "@release-it/conventional-changelog": "^11.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.4.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.15.0",
    "release-it": "^20.0.1",
    "tsup": "^8.5.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.10"
  }
}
